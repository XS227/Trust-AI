<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TrustAI Dashboard+</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f4f7fb;
      --ink: #07111f;
      --muted: #64748b;
      --card: rgba(255,255,255,.88);
      --dark: #07111f;
      --border: #e2e8f0;
      --soft: #f1f5f9;
      --green: #16a34a;
      --orange: #ea580c;
      --blue: #2563eb;
      --shadow: 0 18px 45px rgba(15,23,42,.08);
      --radius: 24px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, system-ui, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, #dff0ff 0, transparent 35%),
        linear-gradient(180deg, #f8fafc, #eef2f7);
      min-height: 100vh;
    }

    .page {
      width: min(1440px, 100%);
      margin: 0 auto;
      padding: 28px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 24px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,.8);
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      box-shadow: 0 6px 16px rgba(15,23,42,.04);
    }

    h1 {
      margin: 12px 0 8px;
      font-size: clamp(34px, 5vw, 64px);
      line-height: .95;
      letter-spacing: -0.06em;
    }

    .lead-text {
      max-width: 760px;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.6;
      margin: 0;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }

    button, .btn {
      border: 0;
      border-radius: 999px;
      padding: 11px 16px;
      background: var(--dark);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: .18s ease;
      box-shadow: 0 8px 18px rgba(15,23,42,.12);
    }

    button.secondary {
      background: #fff;
      color: var(--ink);
      border: 1px solid var(--border);
      box-shadow: none;
    }

    button:hover { transform: translateY(-1px); }
    button.active { background: var(--dark); color: #fff; }

    .grid { display: grid; gap: 16px; }
    .kpis { grid-template-columns: repeat(6, minmax(0, 1fr)); margin-bottom: 16px; }
    .main-grid { grid-template-columns: 2fr 1fr; margin-bottom: 16px; }
    .three-grid { grid-template-columns: 2fr 1fr; margin-bottom: 16px; }
    .bottom-grid { grid-template-columns: 1fr 2fr; }
    .mini-grid { grid-template-columns: repeat(4, 1fr); margin-top: 16px; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(14px);
      overflow: hidden;
    }

    .card-inner { padding: 22px; }
    .metric { min-height: 172px; }

    .metric-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .iconbox {
      width: 46px;
      height: 46px;
      border-radius: 17px;
      background: var(--dark);
      color: #fff;
      display: grid;
      place-items: center;
      font-size: 20px;
    }

    .trend {
      background: #dcfce7;
      color: #15803d;
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 12px;
      font-weight: 800;
    }

    .metric p { margin: 0; color: var(--muted); font-size: 13px; }
    .metric h3 { margin: 18px 0 5px; font-size: 25px; letter-spacing: -0.04em; }

    .dark-card {
      background: var(--dark);
      color: #fff;
      border-color: transparent;
    }

    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 18px;
    }

    .section-head p { margin: 0 0 4px; color: var(--muted); font-size: 13px; }
    .dark-card .section-head p { color: #cbd5e1; }
    .section-head h2 { margin: 0; font-size: 23px; letter-spacing: -0.04em; }

    .score-box {
      background: rgba(255,255,255,.1);
      border-radius: 20px;
      padding: 14px 20px;
      text-align: center;
      min-width: 120px;
    }
    .score-box span { color: #cbd5e1; font-size: 12px; }
    .score-box strong { display: block; font-size: 34px; }

    .funnel-cards {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 10px;
      margin-top: 26px;
    }

    .funnel-step {
      background: rgba(255,255,255,.1);
      border-radius: 20px;
      padding: 15px;
    }
    .funnel-step small { color: #cbd5e1; }
    .funnel-step strong { display: block; margin-top: 8px; font-size: 21px; }
    .funnel-step span { color: #94a3b8; font-size: 11px; }

    .task {
      display: flex;
      gap: 12px;
      padding: 13px;
      background: var(--soft);
      border-radius: 18px;
      margin-bottom: 10px;
      line-height: 1.45;
      font-size: 14px;
      color: #334155;
    }
    .task-num {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--dark);
      color: #fff;
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 800;
      flex: none;
    }

    .lead-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr auto;
      gap: 16px;
      align-items: center;
      border: 1px solid #e9eef5;
      background: #f8fafc;
      border-radius: 20px;
      padding: 16px;
      margin-bottom: 12px;
    }
    .pill {
      display: inline-flex;
      border-radius: 999px;
      padding: 5px 9px;
      background: #ffedd5;
      color: #c2410c;
      font-size: 12px;
      font-weight: 800;
    }
    .lead-row h3 { margin: 9px 0 4px; font-size: 17px; }
    .lead-row p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; }
    .lead-row b { color: var(--ink); }

    .activity-item {
      display: flex;
      gap: 12px;
      margin-bottom: 18px;
    }
    .activity-icon {
      width: 36px;
      height: 36px;
      border-radius: 13px;
      display: grid;
      place-items: center;
      background: var(--soft);
      flex: none;
    }
    .activity-item p { margin: 0; font-size: 14px; font-weight: 700; }
    .activity-item small { color: var(--muted); }

    .bar-row { margin-bottom: 18px; }
    .bar-row header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 700;
    }
    .bar-bg {
      height: 12px;
      border-radius: 999px;
      background: var(--soft);
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      border-radius: inherit;
      background: var(--dark);
      width: 0;
      transition: width 1s ease;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: 20px;
      font-size: 14px;
    }
    th, td { padding: 15px; text-align: left; border-bottom: 1px solid #edf2f7; }
    th { background: #f8fafc; color: var(--muted); font-weight: 700; }
    td { color: #475569; }
    td:first-child { color: var(--ink); font-weight: 800; }

    .tag {
      display: inline-flex;
      background: var(--dark);
      color: #fff;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 12px;
      font-weight: 800;
    }

    .searchbox {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--muted);
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 13px;
    }

    .mini-card .card-inner {
      display: flex;
      gap: 13px;
      align-items: center;
      padding: 18px;
    }
    .mini-card p { margin: 0; color: var(--muted); font-size: 13px; }
    .mini-card h3 { margin: 3px 0 0; font-size: 16px; }

    .floating-alert {
      position: fixed;
      right: 22px;
      bottom: 22px;
      width: min(360px, calc(100% - 44px));
      background: var(--dark);
      color: #fff;
      border-radius: 22px;
      padding: 18px;
      box-shadow: 0 22px 60px rgba(15,23,42,.25);
      display: none;
      z-index: 10;
    }
    .floating-alert.show { display: block; animation: pop .3s ease; }
    .floating-alert p { margin: 6px 0 0; color: #cbd5e1; font-size: 14px; }
    @keyframes pop { from { transform: translateY(20px); opacity: 0; } to { transform: none; opacity: 1; } }

    @media (max-width: 1180px) {
      .kpis { grid-template-columns: repeat(3, 1fr); }
      .funnel-cards { grid-template-columns: repeat(3, 1fr); }
      .mini-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 860px) {
      .page { padding: 18px; }
      .topbar, .section-head { align-items: flex-start; flex-direction: column; }
      .actions { justify-content: flex-start; }
      .kpis, .main-grid, .three-grid, .bottom-grid, .mini-grid { grid-template-columns: 1fr; }
      .funnel-cards { grid-template-columns: repeat(2, 1fr); }
      .lead-row { grid-template-columns: 1fr; }
      table { min-width: 760px; }
      .table-wrap { overflow-x: auto; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="topbar">
      <div>
        <div class="badge">✦ TrustAI Ambassador Intelligence</div>
        <h1>Dashboard+</h1>
        <p class="lead-text">Fra delt lenke til betalt ordre – med klikk, varme leads, pipeline, inntekt, utbetaling og anbefalte neste steg.</p>
      </div>
      <div class="actions">
        <button class="secondary period active">I dag</button>
        <button class="secondary period">Denne uken</button>
        <button class="secondary period">Denne måneden</button>
        <button onclick="copyReferral()">🔗 Kopier lenke</button>
      </div>
    </section>

    <section class="grid kpis">
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">✉️</div><span class="trend">+18%</span></div><h3>184</h3><p>Delte lenker</p><p>+28 denne uken</p></div></article>
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">🖱️</div><span class="trend">+34%</span></div><h3>1 428</h3><p>Totale klikk</p><p>312 direkte / 1 116 åpne</p></div></article>
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">👁️</div><span class="trend">+9%</span></div><h3>37</h3><p>Aktive besøk</p><p>Siste 24 timer</p></div></article>
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">🎯</div><span class="trend">+21%</span></div><h3>26</h3><p>Nye leads</p><p>8 varme leads</p></div></article>
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">📈</div><span class="trend">+41%</span></div><h3>482 000 kr</h3><p>Pipeline-verdi</p><p>Tilbud + møter</p></div></article>
      <article class="card metric"><div class="card-inner"><div class="metric-top"><div class="iconbox">💰</div><span class="trend">+12%</span></div><h3>42 850 kr</h3><p>Din provisjon</p><p>17 400 kr tilgjengelig</p></div></article>
    </section>

    <section class="grid main-grid">
      <article class="card dark-card">
        <div class="card-inner">
          <div class="section-head">
            <div><p>Din salgsreise</p><h2>Klikk → aktivitet → lead → betaling</h2></div>
            <div class="score-box"><span>Ambassadør score</span><strong>86</strong></div>
          </div>
          <div class="funnel-cards">
            <div class="funnel-step"><small>Klikk</small><strong>1 428</strong><span>100%</span></div>
            <div class="funnel-step"><small>Engasjerte</small><strong>512</strong><span>36%</span></div>
            <div class="funnel-step"><small>Kontakter</small><strong>81</strong><span>16%</span></div>
            <div class="funnel-step"><small>Møter</small><strong>31</strong><span>38%</span></div>
            <div class="funnel-step"><small>Tilbud</small><strong>14</strong><span>45%</span></div>
            <div class="funnel-step"><small>Godkjent</small><strong>5</strong><span>36%</span></div>
          </div>
        </div>
      </article>

      <article class="card">
        <div class="card-inner">
          <div class="section-head"><div><p>Neste beste handling</p><h2>Hva bør du gjøre nå?</h2></div><span>🚀</span></div>
          <div class="task"><div class="task-num">1</div><div>Følg opp Nordic Retail AS i dag – de åpnet tilbudet nylig.</div></div>
          <div class="task"><div class="task-num">2</div><div>Bruk SMS-teksten igjen. Den har høyest konvertering akkurat nå.</div></div>
          <div class="task"><div class="task-num">3</div><div>Del LinkedIn-posten på nytt tirsdag morgen. Beste historiske tidspunkt.</div></div>
        </div>
      </article>
    </section>

    <section class="grid three-grid">
      <article class="card">
        <div class="card-inner">
          <div class="section-head"><div><p>Hot leads</p><h2>Leads du bør følge opp</h2></div><button class="secondary">Se alle ›</button></div>
          <div class="lead-row"><div><span class="pill">Hot</span><h3>Nordic Retail AS</h3><p>Marius H.</p></div><div><p>Åpnet tilbudet for 18 minutter siden</p><p><b>Estimert verdi: 96 000 kr</b></p></div><button>Åpne ↗</button></div>
          <div class="lead-row"><div><span class="pill">Varm</span><h3>Læringspartner Norge</h3><p>Sofia K.</p></div><div><p>Besøkte priser + case-siden 3 ganger</p><p><b>Estimert verdi: 58 000 kr</b></p></div><button>Åpne ↗</button></div>
          <div class="lead-row"><div><span class="pill">Møte</span><h3>Byggkompetanse AS</h3><p>Thomas R.</p></div><div><p>Booket møte via din lenke</p><p><b>Estimert verdi: 120 000 kr</b></p></div><button>Åpne ↗</button></div>
        </div>
      </article>

      <article class="card">
        <div class="card-inner">
          <div class="section-head"><div><p>Live aktivitet</p><h2>Akkurat nå</h2></div><span>🔔</span></div>
          <div class="activity-item"><div class="activity-icon">👁️</div><div><p>Ny besøkende fra LinkedIn</p><small>2 min siden</small></div></div>
          <div class="activity-item"><div class="activity-icon">✉️</div><div><p>E-posttekst “Opplæring” fikk 7 klikk</p><small>14 min siden</small></div></div>
          <div class="activity-item"><div class="activity-icon">✅</div><div><p>Tilbud flyttet til Godkjent</p><small>1 t siden</small></div></div>
          <div class="activity-item"><div class="activity-icon">🔥</div><div><p>Lead score økte til 94</p><small>2 t siden</small></div></div>
        </div>
      </article>
    </section>

    <section class="grid bottom-grid">
      <article class="card">
        <div class="card-inner">
          <div class="section-head"><div><p>Funnel analytics</p><h2>Hvor mister du folk?</h2></div></div>
          <div class="bar-row"><header><span>Klikk</span><span>1 428</span></header><div class="bar-bg"><div class="bar-fill" data-width="100%"></div></div></div>
          <div class="bar-row"><header><span>Engasjerte besøk</span><span>512</span></header><div class="bar-bg"><div class="bar-fill" data-width="36%"></div></div></div>
          <div class="bar-row"><header><span>Kontakter</span><span>81</span></header><div class="bar-bg"><div class="bar-fill" data-width="16%"></div></div></div>
          <div class="bar-row"><header><span>Møter</span><span>31</span></header><div class="bar-bg"><div class="bar-fill" data-width="38%"></div></div></div>
          <div class="bar-row"><header><span>Tilbud</span><span>14</span></header><div class="bar-bg"><div class="bar-fill" data-width="45%"></div></div></div>
          <div class="bar-row"><header><span>Godkjent</span><span>5</span></header><div class="bar-bg"><div class="bar-fill" data-width="36%"></div></div></div>
        </div>
      </article>

      <article class="card">
        <div class="card-inner">
          <div class="section-head">
            <div><p>Innhold som fungerer</p><h2>Beste tekster, kanaler og konvertering</h2></div>
            <div class="searchbox">🔎 Søk i kampanjer</div>
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Tekst / kampanje</th><th>Kanal</th><th>Klikk</th><th>Leads</th><th>Konv.</th><th>Status</th></tr></thead>
              <tbody>
                <tr><td>LinkedIn – kort anbefaling</td><td>LinkedIn</td><td>428</td><td>19</td><td><b>4.4%</b></td><td><span class="tag">Best</span></td></tr>
                <tr><td>E-post – opplæring</td><td>E-post</td><td>211</td><td>14</td><td><b>6.6%</b></td><td><span class="tag">Høy konv.</span></td></tr>
                <tr><td>SMS – personlig intro</td><td>SMS</td><td>86</td><td>9</td><td><b>10.4%</b></td><td><span class="tag">Sterk</span></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </article>
    </section>

    <section class="grid mini-grid">
      <article class="card mini-card"><div class="card-inner"><span>🛡️</span><div><p>Attribution</p><h3>First click / 90 dager</h3></div></div></article>
      <article class="card mini-card"><div class="card-inner"><span>⏱️</span><div><p>Neste utbetaling</p><h3>17 400 kr klar</h3></div></div></article>
      <article class="card mini-card"><div class="card-inner"><span>🏆</span><div><p>Ranking</p><h3>#3 av 120</h3></div></div></article>
      <article class="card mini-card"><div class="card-inner"><span>🔗</span><div><p>Beste kanal</p><h3>SMS / personlig</h3></div></div></article>
    </section>
  </main>

  <div class="floating-alert" id="toast">
    <strong>Lenke kopiert</strong>
    <p>Din unike TrustAI-lenke er klar til deling.</p>
  </div>

  <script>
    const periods = document.querySelectorAll('.period');
    periods.forEach(btn => {
      btn.addEventListener('click', () => {
        periods.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    window.addEventListener('load', () => {
      document.querySelectorAll('.bar-fill').forEach(bar => {
        setTimeout(() => bar.style.width = bar.dataset.width, 250);
      });
    });

    function copyReferral() {
      const link = 'https://trustai.no/a/AMB-4281';
      if (navigator.clipboard) navigator.clipboard.writeText(link);
      const toast = document.getElementById('toast');
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2600);
    }
  </script>
</body>
</html>
